# ─── KGP Catalyst — Frontend Environment Variables ────────────────────────────
# Copy this file to .env.local for development, or set on your hosting platform.

# Backend API base URL.
# - Leave EMPTY for same-origin deployment (frontend + backend on same domain)
#   OR when using the Vite dev proxy (localhost dev — already configured).
# - Set to full backend URL for separate deployments:
#   Example: https://kgp-catalyst-api.onrender.com
VITE_API_BASE_URL=
