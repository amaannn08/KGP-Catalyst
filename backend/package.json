{
  "name": "kgp-catalyst-backend",
  "version": "1.0.0",
  "description": "RAG-powered Socratic chatbot backend for IIT KGP students",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "ingest": "node ingest.js",
