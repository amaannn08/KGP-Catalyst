# ─── KGP Catalyst — Backend Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.

# Gemini — used for embeddings (gemini-embedding-001, 1536 dims)
GEMINI_API_KEY=

# DeepSeek — used for chat completions
DEEPSEEK_API_KEY=

# NeonDB (PostgreSQL + pgvector)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Path to scraped JSONL file (used by ingest.js)
JSONL_PATH=./iitkgp.jsonl

# Server port
PORT=5000

# CORS — deployed frontend origin (leave blank for localhost-only dev)
# Example: https://kgp-catalyst.vercel.app
FRONTEND_URL=

# Set to 'production' on your hosting platform to disable request logging
NODE_ENV=development
