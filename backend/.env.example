# ──────────────────────────────────────────────────────────────
# KGP Catalyst — Backend Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────

# NeonDB PostgreSQL connection string (from the Neon dashboard)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Gemini API Key — used for embeddings (text-embedding-004, 768 dims)
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API Key — used for chat completions only
# Obtain from: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Path to your JSONL data file (used by ingest.js only)
JSONL_PATH=./iitkgp.jsonl

# Express server port
PORT=5000
